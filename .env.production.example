# ==========================================================================
# 生产环境变量模板 —— 复制为 .env.production 并填值：
#     cp .env.production.example .env.production
# 只需填「两个数据库口令 + 一个会话密钥」；DATABASE_URL 会由下面的 MYSQL_* 自动拼装，
# 访问地址由 nginx 自动识别（trustHost），均无需手填。
# .env.production 已被 .gitignore 忽略，切勿提交！
# ==========================================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_strong_pwd
MYSQL_DATABASE=exam_system
MYSQL_USER=exam
MYSQL_PASSWORD=CHANGE_ME_exam_strong_pwd

# ---- 会话密钥（用 `openssl rand -base64 32` 生成后替换）----
NEXTAUTH_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# ---- 以下均为可选，一般无需填写 ----
# 手动覆盖数据库连接串（默认由上面 MYSQL_* 自动拼装；口令含特殊字符时可在此手写并做 URL 编码）：
# DATABASE_URL="mysql://exam:pwd@db:3306/exam_system"
# 手动指定对外访问地址（默认由 nginx 请求头自动识别，通常留空即可）：
# NEXTAUTH_URL="https://exam.example.com"
