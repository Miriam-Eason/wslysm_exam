# ==========================================================================
# 生产环境变量模板 —— 复制为 .env.production 并填入真实值：
#     cp .env.production.example .env.production
# .env.production 已被 .gitignore 忽略，切勿提交！
# ==========================================================================

# ---- MySQL（db 服务读取）----
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_strong_pwd
MYSQL_DATABASE=exam_system
MYSQL_USER=exam
MYSQL_PASSWORD=CHANGE_ME_exam_strong_pwd

# ---- 应用（app 服务读取）----
# 注意：主机名必须是 compose 服务名 db；用户名/密码/库名要与上面 MYSQL_* 一致
DATABASE_URL="mysql://exam:CHANGE_ME_exam_strong_pwd@db:3306/exam_system"

# NextAuth 会话密钥 —— 用 `openssl rand -base64 32` 生成后替换
NEXTAUTH_SECRET="CHANGE_ME_run_openssl_rand_base64_32"

# 浏览器访问系统的地址（域名或 IP，含端口）；影响登录回调与 Cookie
# 例：http://192.168.1.10 或 https://exam.example.com
NEXTAUTH_URL="http://localhost"
